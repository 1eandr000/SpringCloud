<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.leandro.mapper.UserMapper">

    <!-- user 是 MySQL 关键字，表名必须加反引号 -->
    <select id="findById" resultType="com.leandro.entity.User">
        SELECT id, username, password, name, gender, age, money, card, phone
        FROM `user`
        WHERE id = #{id}
    </select>

</mapper>